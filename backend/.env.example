# Backend environment variables
# Copy this to .env and fill in your values

PORT=5001
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/studyconnect_global?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Email (Gmail App Password — NOT your account password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM="StudyConnect Global <your_email@gmail.com>"

# Frontend URL (comma-separated for multiple)
# Local: http://localhost:5173
# Production: https://studyconnect-global.vercel.app
FRONTEND_URL=http://localhost:5173

MAX_REQUESTS_PER_DAY=10
